{
  "name": "pilaoban-grading-tool",
  "version": "2.1.1",
  "description": "皮老板智能阅卷工具 - AI智能评分",
  "main": "dist/main/main.js",
  "author": "皮老板",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:green": "npm run build && electron-builder --win && npm run pack:green",
    "pack:green": "cd release && 7z a -r \"皮老板智能阅卷工具-v$(node -p \"require('../package.json').version\")-绿色免安装版.zip\" win-unpacked/ || zip -r \"皮老板智能阅卷工具-v$(node -p \"require('../package.json').version\")-绿色免安装版.zip\" win-unpacked/"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "dayjs": "^1.11.10",
    "electron-store": "^8.1.0",
    "form-data": "^4.0.5",
    "framer-motion": "^10.16.5",
    "lucide-react": "^0.294.0",
    "onnxruntime-web": "^1.26.0",
    "paddleocr": "^1.1.1",
    "playwright": "^1.60.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.0",
    "tesseract.js": "^5.1.1",
    "uuid": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.39",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "sass": "^1.69.5",
    "typescript": "^5.3.2",
    "vite": "^5.0.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.pilaoban.grading-tool",
    "productName": "皮老板智能阅卷工具 v2.1.1",
    "copyright": "Copyright © 2026 皮老板",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "dist/main/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "portable": {
      "artifactName": "皮老板智能阅卷工具-${version}-绿色版.exe"
    }
  }
}
